# ------------------------------------------------------------------------------
# Helper: scan a directory recursively and find a file that ends with a suffix
# ------------------------------------------------------------------------------
find_file <- function(base, suffix) {
  all_files <- list.files(base, recursive = TRUE, full.names = TRUE)
  hits <- all_files[grepl(paste0(gsub("\\.", "\\\\.", suffix), "$"), all_files)]
  if (length(hits) == 0) return(NA_character_)
  return(hits[1])
}

# Helper: safely close stale gz connections
close_stale_gz_connections <- function() {
  open_cons <- getAllConnections()
  for (con_id in open_cons) {
    tryCatch({
      con_info <- summary.connection(getConnection(con_id))
      if (grepl("\\.gz$", con_info$description, ignore.case = TRUE)) {
        close(getConnection(con_id))
      }
    }, error = function(e) NULL)
  }
}

