# Helper: resolve a gene name from CellChatDB (handles complexes like "TGFBR1_TGFBR2")
resolve_genes <- function(gene_str, complex_db) {
  if (is.na(gene_str) || gene_str == "") return(character(0))
  # Check if it's a complex name
  if (gene_str %in% rownames(complex_db)) {
    subunits <- complex_db[gene_str, ]
    subunits <- subunits[!is.na(subunits) & subunits != ""]
    return(as.character(subunits))
  }
  # Otherwise treat as a single gene or underscore-separated list
  genes <- unlist(strsplit(gene_str, "_"))
  return(genes)
}

