            DefaultAssay(obj) <- an
            mat <- tryCatch(
              GetAssayData(obj, layer = layer),
              error = function(e) {
                tryCatch(GetAssayData(obj, slot = layer),
                         error = function(e2) NULL)
              })
            if (!is.null(mat) && ncol(mat) > 0 && nrow(mat) > 0)
