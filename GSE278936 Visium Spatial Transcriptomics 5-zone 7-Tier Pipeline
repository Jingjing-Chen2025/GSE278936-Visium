      y_range <- diff(range(coords[, 2], na.rm = TRUE))
      area <- x_range * y_range
      if (area <= 0) return(1.5)
      density <- nrow(coords) / area
      size <- max(0.3, min(3.0, 1 / sqrt(density) * 10))
      return(size)
