# ==============================================================================
# Helper: compute optimal spot size based on actual spot spacing per sample
# ==============================================================================
compute_optimal_pt_size <- function(md, x_col = "spatial_x", y_col = "spatial_y",
                                    target_plot_width = 10, dpi = 200) {
  x_range <- diff(range(md[[x_col]], na.rm = TRUE))
  y_range <- diff(range(md[[y_col]], na.rm = TRUE))
  coord_range <- max(x_range, y_range)

  if (coord_range == 0 || nrow(md) < 2) return(2.8)

  if ("array_row" %in% colnames(md) && "array_col" %in% colnames(md)) {
    row_vals <- sort(unique(md$array_row))
    if (length(row_vals) >= 2) {
      rows_in_range <- length(row_vals)
      if (rows_in_range > 1) {
        pixel_per_array_unit <- y_range / (max(row_vals) - min(row_vals))
        row_spacing_array <- median(diff(row_vals))
        spot_spacing_px <- pixel_per_array_unit * row_spacing_array
      } else {
        spot_spacing_px <- coord_range / sqrt(nrow(md))
      }
    } else {
      spot_spacing_px <- coord_range / sqrt(nrow(md))
    }
  } else {
    spot_spacing_px <- coord_range / sqrt(nrow(md))
  }

  plot_width_mm <- target_plot_width * 25.4
  mm_per_data_unit <- plot_width_mm / coord_range
  spot_size_mm <- spot_spacing_px * mm_per_data_unit

  # 1.15x overlap factor to eliminate gaps between spots
  optimal_size <- spot_size_mm * 1.15

  # Clamp to reasonable range
  optimal_size <- max(0.5, min(optimal_size, 8.0))

  return(round(optimal_size, 2))
}

# ==============================================================================
# Dual-Mode Spatial Plotting Helper
# Accepts separate pt_size for full-res (no-image) and lowres (overlay)
# Uses aes() + .data pronoun (no deprecated aes_string)
# stroke = 0, shape = 16 for minimal gaps
# ==============================================================================
make_spatial_plot <- function(md, color_col, color_scale, title,
                              img = NULL, sf = NULL,
                              pt_size = 2.8, pt_size_overlay = NULL) {

  if (is.null(pt_size_overlay)) pt_size_overlay <- pt_size

  p_overlay <- NULL
  if (!is.null(img) && !is.null(sf)) {
    p_overlay <- ggplot() +
      annotation_raster(img,
                        xmin = 0, xmax = ncol(img),
                        ymin = -nrow(img), ymax = 0) +
      geom_point(data = md,
                 aes(x = .data[["spatial_x_lowres"]],
                     y = -.data[["spatial_y_lowres"]],
                     color = .data[[color_col]]),
                 size = pt_size_overlay, stroke = 0, shape = 16, alpha = 0.85) +
      color_scale +
      coord_equal() +
      theme_minimal(base_size = 14) +
      ggtitle(paste0(title, " (H&E overlay)")) +
      theme(plot.title   = element_text(size = 15, face = "bold", hjust = 0.5),
            legend.title = element_text(size = 11),
            legend.text  = element_text(size = 9),
            axis.title   = element_blank(),
            axis.text    = element_blank(),
            axis.ticks   = element_blank(),
            panel.grid   = element_blank())
  }

  p_noimage <- ggplot() +
    geom_point(data = md,
               aes(x = .data[["spatial_x"]],
                   y = -.data[["spatial_y"]],
                   color = .data[[color_col]]),
               size = pt_size, stroke = 0, shape = 16, alpha = 0.85) +
    color_scale +
    coord_equal() +
    theme_minimal(base_size = 14) +
    ggtitle(title) +
    theme(plot.title   = element_text(size = 15, face = "bold", hjust = 0.5),
          legend.title = element_text(size = 11),
          legend.text  = element_text(size = 9),
          axis.title   = element_blank(),
          axis.text    = element_blank(),
          axis.ticks   = element_blank(),
          panel.grid   = element_blank(),
          panel.background = element_rect(fill = "white", color = NA))

  return(list(overlay = p_overlay, noimage = p_noimage))
}

save_both <- function(plot_list, base_name, plots_dir, w = 10, h = 10) {
