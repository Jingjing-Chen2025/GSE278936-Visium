    ggsave(fp_ov, plot_list$overlay, width = w, height = h, dpi = 200, bg = "white")
    cat(paste0("    saved: ", base_name, "_overlay.png\n"))
  }
}

# Safe wrapper for AddModuleScore that catches binning errors
safe_AddModuleScore <- function(obj, features, name, ctrl, nbin) {
  tryCatch({
    obj <- AddModuleScore(obj, features = features, name = name,
                          ctrl = ctrl, nbin = nbin)
    return(list(obj = obj, success = TRUE))
  }, error = function(e1) {
    reduced_nbin <- max(3, floor(nbin / 2))
    cat(paste0("    Warning: nbin=", nbin, " failed, retrying with nbin=", reduced_nbin, "\n"))
    tryCatch({
      obj <- AddModuleScore(obj, features = features, name = name,
                            ctrl = ctrl, nbin = reduced_nbin)
      return(list(obj = obj, success = TRUE))
    }, error = function(e2) {
      cat(paste0("    Warning: nbin=", reduced_nbin, " also failed, trying nbin=3\n"))
      tryCatch({
        obj <- AddModuleScore(obj, features = features, name = name,
                              ctrl = ctrl, nbin = 3)
        return(list(obj = obj, success = TRUE))
      }, error = function(e3) {
        cat(paste0("    ERROR: AddModuleScore failed completely: ", e3$message, "\n"))
        cat(paste0("    Falling back to manual mean-expression scoring.\n"))
        return(list(obj = obj, success = FALSE))
      })
    })
  })
}

# Manual fallback: simple mean of scaled gene expression
manual_module_score <- function(obj, gene_list, score_name, ctrl_size) {
  avail <- gene_list[gene_list %in% rownames(obj)]
  if (length(avail) == 0) return(obj)
  expr_mat <- GetAssayData(obj, slot = "data")
  gene_expr <- expr_mat[avail, , drop = FALSE]
  scores <- colMeans(as.matrix(gene_expr))
  set.seed(42)
  bg_genes <- sample(setdiff(rownames(obj), avail),
                     size = min(ctrl_size, length(setdiff(rownames(obj), avail))))
  if (length(bg_genes) > 0) {
    bg_expr <- colMeans(as.matrix(expr_mat[bg_genes, , drop = FALSE]))
    scores <- scores - bg_expr
  }
  obj[[score_name]] <- scores
  return(obj)
}

# ==============================================================================
# Helper: safely close all stale gzfile connections (avoids connection leak)
# ==============================================================================
close_stale_gz_connections <- function() {
  open_cons <- getAllConnections()
  for (con_id in open_cons) {
    tryCatch({
      con_info <- summary.connection(getConnection(con_id))
      if (grepl("\\.gz$", con_info$description, ignore.case = TRUE)) {
        close(getConnection(con_id))
      }
    }, error = function(e) NULL)
  }
}


