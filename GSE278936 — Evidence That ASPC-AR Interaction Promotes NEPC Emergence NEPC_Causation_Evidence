safe_GetAssayData <- function(obj, layer_name = "data") {
  tryCatch({ GetAssayData(obj, layer = layer_name) },
  error = function(e) {
    tryCatch({ GetAssayData(obj, slot = layer_name) },
    error = function(e2) { obj[[DefaultAssay(obj)]]@data })
  })
}

