    key        = paste(sample, barcode, sep = "||")
  )

for (nm in names(sample_cache)) {
  md <- sample_cache[[nm]]$md
  md$key <- paste(md$sample, md$barcode, sep = "||")
  idx <- match(md$key, pool_df$key)

  md$ASPC_z      <- pool_df$ASPC_z[idx]
  md$AR_z        <- pool_df$AR_z[idx]
  md$NEPC_UP_z   <- pool_df$NEPC_UP_z[idx]
  md$NEPC_DN_z   <- pool_df$NEPC_DN_z[idx]
  md$NEPC_comp_z <- pool_df$NEPC_comp_z[idx]

  md$is_NEPC_spot <- (md$NEPC_UP_z > NEPC_UP_CUT) & (md$NEPC_DN_z < NEPC_DN_CUT)
  md$is_NEPC_spot[is.na(md$is_NEPC_spot)] <- FALSE

  ar   <- md$AR_1;   ar[is.na(ar)] <- 0
  aspc <- md$ASPC_1; aspc[is.na(aspc)] <- 0

  md$spot_pheno <- ifelse(
    ar > 0 & !md$is_NEPC_spot, "AR_epithelial",
  ifelse(
    md$is_NEPC_spot & ar <= 0, "NEPC",
  ifelse(
    ar > 0 & md$is_NEPC_spot, "Transition",
  ifelse(
    aspc > 0 & ar <= 0 & !md$is_NEPC_spot, "Stromal_ASPC",
    "Other"))))
  md$spot_pheno[is.na(md$spot_pheno)] <- "Other"

  n_spots  <- nrow(md)
  n_nepc   <- sum(md$spot_pheno == "NEPC", na.rm = TRUE)
  pct_nepc <- if (n_spots > 0) 100 * n_nepc / n_spots else 0
  if (is.na(pct_nepc)) pct_nepc <- 0
  md$pct_NEPC_spots <- pct_nepc

  md$sample_type <- if (sample_cache[[nm]]$group %in% BENIGN_GROUPS) {
    "Benign"
  } else if (pct_nepc > NEPC_SAMPLE_PCT) {
    "NEPC_sample"
  } else {
    "Adeno_sample"
  }

  sample_cache[[nm]]$md <- md
}

cat(sprintf("  Stricter NEPC rule: z(NEPC_UP) > %.2f AND z(NEPC_DN) < %.2f\n",
            NEPC_UP_CUT, NEPC_DN_CUT))
cat(sprintf("  BPH forced to 'Benign' (BENIGN_GROUPS = %s)\n",
            paste(BENIGN_GROUPS, collapse=",")))

# ==============================================================================
# 4. PASS 2 — Interface geometry + per-sample evidence
# ==============================================================================
cat("\n========== PASS 2: Interface geometry + evidence ==========\n")

all_evidence    <- list()
all_sample_smry <- list()

for (nm in names(sample_cache)) {
  cat(paste0("\n--- ", nm, " ---\n"))
  ent <- sample_cache[[nm]]
  md  <- ent$md
  grp <- ent$group

  spot_radius <- ent$sf_json$spot_diameter_fullres * 3
  all_xy <- as.matrix(md[, c("spatial_x","spatial_y")])
  n_spots <- nrow(md)

  md$at_ASPC_AR_interface <- FALSE
  md$dist_to_nearest_ASPC <- NA_real_
  md$dist_to_nearest_AR   <- NA_real_

  aspc_idx <- which(md$spot_pheno == "Stromal_ASPC")
  ar_idx   <- which(md$spot_pheno == "AR_epithelial")

  if (length(aspc_idx) >= 3 && length(ar_idx) >= 3) {
    aspc_xy <- all_xy[aspc_idx,,drop=FALSE]
    ar_xy   <- all_xy[ar_idx,,drop=FALSE]
    for (i in seq_len(n_spots)) {
      md$dist_to_nearest_ASPC[i] <- min(sqrt((aspc_xy[,1]-all_xy[i,1])^2 +
                                             (aspc_xy[,2]-all_xy[i,2])^2))
      md$dist_to_nearest_AR[i]   <- min(sqrt((ar_xy[,1]-all_xy[i,1])^2 +
                                             (ar_xy[,2]-all_xy[i,2])^2))
    }
    for (i in seq_len(n_spots)) {
      dists <- sqrt((all_xy[,1]-all_xy[i,1])^2 + (all_xy[,2]-all_xy[i,2])^2)
      nbrs  <- which(dists > 0 & dists <= spot_radius)
      nbr_ph <- md$spot_pheno[nbrs]
      if (any(nbr_ph == "Stromal_ASPC") && any(nbr_ph == "AR_epithelial"))
        md$at_ASPC_AR_interface[i] <- TRUE
    }
  }

  n_interface <- sum(md$at_ASPC_AR_interface, na.rm = TRUE)
  n_nepc      <- sum(md$spot_pheno == "NEPC", na.rm = TRUE)

  # ------------ EVIDENCE 1: NEPC gradient in AR+ spots vs dist to ASPC -------
  ev1 <- NULL; ev1_cor <- NULL
  ar_spots_md <- md[md$spot_pheno == "AR_epithelial", ]
  if (nrow(ar_spots_md) >= 20 && length(aspc_idx) >= 5) {
    qs <- quantile(ar_spots_md$dist_to_nearest_ASPC,
                   probs = seq(0,1,0.25), na.rm = TRUE)
    if (length(unique(qs)) >= 3) {
      ar_spots_md$dist_cat <- cut(ar_spots_md$dist_to_nearest_ASPC,
                                  breaks = qs, include.lowest = TRUE,
                                  labels = c("Q1_nearest","Q2","Q3","Q4_farthest"))
      ev1 <- ar_spots_md %>%
        filter(!is.na(dist_cat)) %>%
        group_by(dist_cat) %>%
        summarize(
          N = n(),
          Mean_NEPC      = mean(NEPC_composite, na.rm = TRUE),
          Mean_NEPC_onco = if ("NEPC_onco_1" %in% colnames(ar_spots_md))
                             mean(NEPC_onco_1, na.rm = TRUE) else NA,
          Mean_EMT       = if ("EMT_1" %in% colnames(ar_spots_md))
                             mean(EMT_1, na.rm = TRUE) else NA,
          .groups = "drop"
        ) %>%
        mutate(sample = nm, group = grp)
      ev1_cor <- suppressWarnings(cor.test(
        ar_spots_md$dist_to_nearest_ASPC, ar_spots_md$NEPC_composite,
        method = "spearman"))
    }
  }

  # ------------ EVIDENCE 2: Transition enrichment at interface ---------------
  ev2 <- NULL
  if (n_interface >= 5 && sum(md$spot_pheno == "Transition", na.rm = TRUE) >= 1) {
    n_trans_at_iface  <- sum(md$spot_pheno == "Transition" &  md$at_ASPC_AR_interface, na.rm = TRUE)
    n_trans_not_iface <- sum(md$spot_pheno == "Transition" & !md$at_ASPC_AR_interface, na.rm = TRUE)
    n_other_at_iface  <- sum(md$spot_pheno != "Transition" &  md$at_ASPC_AR_interface, na.rm = TRUE)
    n_other_not_iface <- sum(md$spot_pheno != "Transition" & !md$at_ASPC_AR_interface, na.rm = TRUE)
    fisher_mat <- matrix(c(n_trans_at_iface, n_trans_not_iface,
                           n_other_at_iface, n_other_not_iface), nrow = 2)
    ft <- tryCatch(fisher.test(fisher_mat), error = function(e) NULL)
    ev2 <- data.frame(
      sample = nm, group = grp,
      N_Transition_at_interface = n_trans_at_iface,
      N_Transition_away = n_trans_not_iface,
      Pct_Trans_at_interface = round(n_trans_at_iface /
                                     max(1, n_trans_at_iface + n_trans_not_iface) * 100, 1),
      Fisher_OR = if (!is.null(ft)) round(ft$estimate, 3) else NA,
      Fisher_p  = if (!is.null(ft)) signif(ft$p.value, 4) else NA
    )
  }

  # ------------ EVIDENCE 3: Distance-dependent NEPC --------------------------
  ev3_cor <- NA_real_
  if (sum(!is.na(md$dist_to_nearest_ASPC)) >= 20) {
    ev3_cor <- suppressWarnings(
      cor(md$dist_to_nearest_ASPC, md$NEPC_composite,
          method = "spearman", use = "complete.obs"))
  }

  # ------------ EVIDENCE 4: L-R at interface ---------------------------------
  ev4 <- data.frame()
  if (!is.null(ent$lr_expr)) {
    lr_expr <- ent$lr_expr
    rn <- rownames(lr_expr)
    for (j in seq_len(nrow(plasticity_LR))) {
      lig <- plasticity_LR$Ligand[j]; rec <- plasticity_LR$Receptor[j]
      if (lig %in% rn && rec %in% rn) {
        lig_e <- as.numeric(lr_expr[lig, ])
        rec_e <- as.numeric(lr_expr[rec, ])
        int_score <- sqrt(pmax(lig_e, 0) * pmax(rec_e, 0))
        mean_at <- mean(int_score[md$at_ASPC_AR_interface], na.rm = TRUE)
        mean_aw <- mean(int_score[!md$at_ASPC_AR_interface], na.rm = TRUE)
        ev4 <- rbind(ev4, data.frame(
          sample = nm, group = grp,
          Ligand = lig, Receptor = rec,
          Pathway = plasticity_LR$Pathway[j],
          NE_link = plasticity_LR$NE_link[j],
          Mean_at_interface = round(mean_at, 4),
          Mean_away         = round(mean_aw, 4),
          Fold_enrichment   = round(mean_at / (mean_aw + 1e-4), 2),
          stringsAsFactors = FALSE
        ))
      }
    }
  }

  # ------------ Sample summary ------------------------------------------------
  smry <- data.frame(
    Sample = nm, Group = grp,
    Sample_type    = md$sample_type[1],
    N_spots        = nrow(md),
    N_AR           = sum(md$spot_pheno == "AR_epithelial", na.rm = TRUE),
    N_NEPC         = n_nepc,
    N_ASPC         = sum(md$spot_pheno == "Stromal_ASPC", na.rm = TRUE),
    N_Transition   = sum(md$spot_pheno == "Transition",   na.rm = TRUE),
    N_Interface    = n_interface,
    Pct_Interface  = round(n_interface / nrow(md) * 100, 1),
    Pct_NEPC       = round(n_nepc      / nrow(md) * 100, 1),
    Pct_Transition = round(sum(md$spot_pheno == "Transition", na.rm = TRUE) / nrow(md) * 100, 1),
    NEPC_gradient_cor = if (!is.null(ev1_cor)) round(ev1_cor$estimate, 4) else NA_real_,
    NEPC_gradient_p   = if (!is.null(ev1_cor)) signif(ev1_cor$p.value, 4) else NA_real_,
    Trans_at_interface_OR = if (!is.null(ev2)) ev2$Fisher_OR else NA,
    Trans_at_interface_p  = if (!is.null(ev2)) ev2$Fisher_p else NA,
    Dist_NEPC_cor = round(ev3_cor, 4),
    stringsAsFactors = FALSE
  )

  all_sample_smry[[nm]] <- smry
  all_evidence[[nm]] <- list(ev1 = ev1, ev2 = ev2, ev3_cor = ev3_cor, ev4 = ev4, md = md)

  cat(paste0("  DONE -> ", md$sample_type[1],
             " | Interface=", n_interface,
             " | %NEPC=", round(100*n_nepc/nrow(md),1),
             " | NEPC_gradient_cor=", smry$NEPC_gradient_cor, "\n"))
}

