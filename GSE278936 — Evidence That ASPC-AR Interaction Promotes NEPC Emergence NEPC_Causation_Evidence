find_file <- function(base, suffix) {
  hits <- list.files(base, recursive=TRUE, full.names=TRUE)
  hits <- hits[grepl(paste0(gsub("\\.","\\\\.",suffix),"$"), hits)]
  if (length(hits)==0) return(NA_character_); hits[1]
}

robust_z <- function(x) {
  m <- median(x, na.rm = TRUE)
  s <- mad(x, na.rm = TRUE)
  if (is.na(s) || s == 0) s <- sd(x, na.rm = TRUE)
  if (is.na(s) || s == 0) return(rep(0, length(x)))
  (x - m) / s
}

