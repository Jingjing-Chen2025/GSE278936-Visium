cat("\n========== Processing All Samples ==========\n")

all_evidence <- list()
all_sample_smry <- list()
completed <- c(); skipped <- c()

for (s in samples) {
  nm <- s$name; bd <- s$dir; grp <- s$group
  cat(paste0("\n--- ",nm," [",grp,"] ---\n"))

  # Find files
  f_bc  <- find_file(bd,"barcodes.tsv.gz")
  f_ft  <- find_file(bd,"features.tsv.gz")
  f_mx  <- find_file(bd,"matrix.mtx.gz")
  f_pos <- find_file(bd,"tissue_positions_list.csv")
  f_sf  <- find_file(bd,"scalefactors_json.json")
  f_hi  <- find_file(bd,"tissue_hires_image.png")
  f_lo  <- find_file(bd,"tissue_lowres_image.png")

  req <- c(f_bc,f_ft,f_mx,f_pos,f_sf,f_hi,f_lo)
  if (any(is.na(req))||any(!file.exists(req[!is.na(req)]))) {
    cat("  Missing files — skip\n"); skipped <- c(skipped,nm); next }

  # Load
  barcodes <- readLines(gzfile(f_bc))
  features <- read.delim(gzfile(f_ft),header=FALSE,stringsAsFactors=FALSE)
  mat <- readMM(gzfile(f_mx)); colnames(mat) <- barcodes
  gn <- features$V2; dup <- duplicated(gn)|gn==""
  gn[dup] <- paste0(gn[dup],"_",features$V1[dup]); rownames(mat) <- gn

  pos <- read.csv(f_pos,header=FALSE,stringsAsFactors=FALSE)
  if (grepl("barcode",pos$V1[1],ignore.case=TRUE)) pos <- pos[-1,]
  colnames(pos) <- c("barcode","in_tissue","array_row","array_col","pxl_row","pxl_col")
  pos$in_tissue <- as.integer(pos$in_tissue)
  pos$pxl_row <- as.numeric(pos$pxl_row); pos$pxl_col <- as.numeric(pos$pxl_col)
  rownames(pos) <- pos$barcode
  sf_json <- fromJSON(f_sf)

  common <- intersect(barcodes,pos$barcode)
  it_bc <- pos$barcode[pos$barcode %in% common & pos$in_tissue==1]
  if (length(it_bc)<50) { skipped <- c(skipped,nm); next }

  sobj <- CreateSeuratObject(counts=mat[,it_bc],assay="Spatial",project=nm)
  sobj$spatial_x <- pos[Cells(sobj),"pxl_col"]
  sobj$spatial_y <- pos[Cells(sobj),"pxl_row"]

  sobj[["pct_mt"]] <- PercentageFeatureSet(sobj,pattern="^MT-")
  med_mt <- median(sobj$pct_mt)
  mt_th <- if(med_mt>30) min(100,med_mt+1.5*mad(sobj$pct_mt,constant=1)) else 30
  nf_min <- 200
  if(sum(sobj$nFeature_Spatial>200&sobj$pct_mt<mt_th)<50) nf_min <- 100
  if(sum(sobj$nFeature_Spatial>nf_min&sobj$pct_mt<mt_th)<50) nf_min <- 50
  sobj <- subset(sobj,nFeature_Spatial>nf_min&nFeature_Spatial<10000&pct_mt<mt_th)
  if(ncol(sobj)<30) { skipped <- c(skipped,nm); next }

  sobj <- SCTransform(sobj,assay="Spatial",verbose=FALSE)

  # Scores
  ctrl_sz <- min(100,floor(nrow(sobj)/4)); nb <- max(5,min(24,ncol(sobj)-1))
  safe_score <- function(obj,genes,prefix) {
    av <- genes[genes %in% rownames(obj)]
    if(length(av)<5) return(list(obj=obj,ok=FALSE))
    tryCatch({
      obj <- AddModuleScore(obj,features=list(av),name=prefix,ctrl=ctrl_sz,nbin=nb)
      list(obj=obj,ok=TRUE)
    }, error=function(e) {
      tryCatch({
        obj <- AddModuleScore(obj,features=list(av),name=prefix,ctrl=ctrl_sz,nbin=3)
        list(obj=obj,ok=TRUE)
      }, error=function(e2) {
        em <- safe_GetAssayData(obj,"data")
        sc <- colMeans(as.matrix(em[av,,drop=FALSE]))
        bg <- sample(setdiff(rownames(obj),av),min(ctrl_sz,nrow(obj)-length(av)))
        if(length(bg)>0) sc <- sc-colMeans(as.matrix(em[bg,,drop=FALSE]))
        obj[[paste0(prefix,"1")]] <- sc; list(obj=obj,ok=TRUE)
      })
    })
  }

  r1 <- safe_score(sobj,ASPC_genes,"ASPC_");         sobj <- r1$obj; ok1 <- r1$ok
  r2 <- safe_score(sobj,Hallmark_AR_genes,"AR_");     sobj <- r2$obj; ok2 <- r2$ok
  r3 <- safe_score(sobj,NEPC_Beltran_UP,"NEPC_UP_");  sobj <- r3$obj; ok3 <- r3$ok
  r4 <- safe_score(sobj,NEPC_Beltran_DOWN,"NEPC_DN_"); sobj <- r4$obj; ok4 <- r4$ok
  r5 <- safe_score(sobj,NEPC_oncogenic,"NEPC_onco_"); sobj <- r5$obj; ok5 <- r5$ok
  r6 <- safe_score(sobj,EMT_genes,"EMT_");            sobj <- r6$obj; ok6 <- r6$ok

  if(!ok1||!ok2||!ok3||!ok4) { skipped <- c(skipped,nm); next }
  sobj$NEPC_composite <- sobj$NEPC_UP_1 - sobj$NEPC_DN_1

  # Build metadata
  md <- sobj@meta.data
  md$spatial_x <- sobj$spatial_x; md$spatial_y <- sobj$spatial_y
  md$sample <- nm; md$group <- grp

  # Spot phenotype
  md$spot_pheno <- ifelse(
    md$AR_1>0 & md$NEPC_composite<=0, "AR_epithelial",
  ifelse(
    md$NEPC_composite>0 & md$AR_1<=0, "NEPC",
  ifelse(
    md$AR_1>0 & md$NEPC_composite>0, "Transition",
  ifelse(
    md$ASPC_1>0 & md$AR_1<=0 & md$NEPC_composite<=0, "Stromal_ASPC",
    "Other"))))

  n_nepc <- sum(md$spot_pheno=="NEPC")
  md$sample_type <- ifelse(n_nepc==0,"Adeno_sample","NEPC_sample")

  # -----------------------------------------------------------------------
  # COMPUTE INTERFACE ZONES (ASPC-AR)
  # -----------------------------------------------------------------------
  spot_radius <- sf_json$spot_diameter_fullres * 3
  all_xy <- as.matrix(md[,c("spatial_x","spatial_y")])
  n_spots <- nrow(md)

  md$at_ASPC_AR_interface <- FALSE
  md$dist_to_nearest_ASPC <- NA
  md$dist_to_nearest_AR   <- NA

  aspc_idx <- which(md$spot_pheno=="Stromal_ASPC")
  ar_idx   <- which(md$spot_pheno=="AR_epithelial")

  if (length(aspc_idx)>=3 && length(ar_idx)>=3) {
    aspc_xy <- all_xy[aspc_idx,,drop=FALSE]
    ar_xy   <- all_xy[ar_idx,,drop=FALSE]

    # Distance of every spot to nearest ASPC and nearest AR
    for (i in 1:n_spots) {
      md$dist_to_nearest_ASPC[i] <- min(sqrt((aspc_xy[,1]-all_xy[i,1])^2+(aspc_xy[,2]-all_xy[i,2])^2))
      md$dist_to_nearest_AR[i]   <- min(sqrt((ar_xy[,1]-all_xy[i,1])^2+(ar_xy[,2]-all_xy[i,2])^2))
    }

    # Interface = spots with both ASPC and AR neighbors within radius
    for (i in 1:n_spots) {
      dists <- sqrt((all_xy[,1]-all_xy[i,1])^2+(all_xy[,2]-all_xy[i,2])^2)
      nbrs <- which(dists>0 & dists<=spot_radius)
      nbr_ph <- md$spot_pheno[nbrs]
      if (any(nbr_ph=="Stromal_ASPC") && any(nbr_ph=="AR_epithelial"))
        md$at_ASPC_AR_interface[i] <- TRUE
    }
  }

  n_interface <- sum(md$at_ASPC_AR_interface)

  # -----------------------------------------------------------------------
  # EVIDENCE 1: NEPC score gradient toward ASPC-AR interface
  # For AR_epithelial spots: does NEPC_composite increase near interface?
  # -----------------------------------------------------------------------
  ev1 <- NULL
  ar_spots_md <- md[md$spot_pheno=="AR_epithelial",]
  if (nrow(ar_spots_md)>=20 && length(aspc_idx)>=5) {
    ar_spots_md$dist_cat <- cut(ar_spots_md$dist_to_nearest_ASPC,
                                 breaks=quantile(ar_spots_md$dist_to_nearest_ASPC,
                                                 probs=seq(0,1,0.25),na.rm=TRUE),
                                 include.lowest=TRUE, labels=c("Q1_nearest","Q2","Q3","Q4_farthest"))
    ev1 <- ar_spots_md %>%
      filter(!is.na(dist_cat)) %>%
      group_by(dist_cat) %>%
      summarize(
        N=n(),
        Mean_NEPC=mean(NEPC_composite,na.rm=TRUE),
        Mean_NEPC_onco=if(ok5) mean(NEPC_onco_1,na.rm=TRUE) else NA,
        Mean_EMT=if(ok6) mean(EMT_1,na.rm=TRUE) else NA,
        .groups="drop"
      ) %>%
      mutate(sample=nm, group=grp)
    # Correlation: distance to ASPC vs NEPC score in AR spots
    ev1_cor <- cor.test(ar_spots_md$dist_to_nearest_ASPC, ar_spots_md$NEPC_composite,
                        method="spearman")
  }

  # -----------------------------------------------------------------------
  # EVIDENCE 2: Transition spots at interface
  # Are Transition (AR+/NEPC+) spots enriched at the ASPC-AR interface?
  # -----------------------------------------------------------------------
  ev2 <- NULL
  if (n_interface >= 5 && sum(md$spot_pheno=="Transition")>=1) {
    n_trans_at_iface    <- sum(md$spot_pheno=="Transition" & md$at_ASPC_AR_interface)
    n_trans_not_iface   <- sum(md$spot_pheno=="Transition" & !md$at_ASPC_AR_interface)
    n_other_at_iface    <- sum(md$spot_pheno!="Transition" & md$at_ASPC_AR_interface)
    n_other_not_iface   <- sum(md$spot_pheno!="Transition" & !md$at_ASPC_AR_interface)
    fisher_mat <- matrix(c(n_trans_at_iface, n_trans_not_iface,
                           n_other_at_iface, n_other_not_iface), nrow=2)
    ft <- tryCatch(fisher.test(fisher_mat), error=function(e) NULL)
    ev2 <- data.frame(
      sample=nm, group=grp,
      N_Transition_at_interface=n_trans_at_iface,
      N_Transition_away=n_trans_not_iface,
      Pct_Trans_at_interface=round(n_trans_at_iface/(n_trans_at_iface+n_trans_not_iface)*100,1),
      Fisher_OR=if(!is.null(ft)) round(ft$estimate,3) else NA,
      Fisher_p=if(!is.null(ft)) signif(ft$p.value,4) else NA
    )
  }

  # -----------------------------------------------------------------------
  # EVIDENCE 3: Distance-dependent NEPC score
  # Among ALL spots: does NEPC_composite decrease with distance from ASPC?
  # -----------------------------------------------------------------------
  ev3_cor <- NA
  if (sum(!is.na(md$dist_to_nearest_ASPC))>=20) {
    ev3_cor <- cor(md$dist_to_nearest_ASPC, md$NEPC_composite,
                   method="spearman", use="complete.obs")
  }

  # -----------------------------------------------------------------------
  # EVIDENCE 4: L-R at interface (computed in cross-sample)
  # -----------------------------------------------------------------------
  ev4 <- NULL
  expr_data <- safe_GetAssayData(sobj, "data")
  all_gene_names <- rownames(sobj)

  lr_iface_results <- data.frame()
  for (j in 1:nrow(plasticity_LR)) {
    lig <- plasticity_LR$Ligand[j]; rec <- plasticity_LR$Receptor[j]
    if (lig %in% all_gene_names && rec %in% all_gene_names) {
      lig_e <- as.numeric(expr_data[lig,])
      rec_e <- as.numeric(expr_data[rec,])
      int_score <- sqrt(pmax(lig_e,0)*pmax(rec_e,0))

      # Mean interaction at interface vs away
      mean_at_iface <- mean(int_score[md$at_ASPC_AR_interface], na.rm=TRUE)
      mean_away     <- mean(int_score[!md$at_ASPC_AR_interface], na.rm=TRUE)

      lr_iface_results <- rbind(lr_iface_results, data.frame(
        sample=nm, group=grp,
        Ligand=lig, Receptor=rec, Pathway=plasticity_LR$Pathway[j],
        NE_link=plasticity_LR$NE_link[j],
        Mean_at_interface=round(mean_at_iface,4),
        Mean_away=round(mean_away,4),
        Fold_enrichment=round(mean_at_iface/(mean_away+0.0001),2),
        stringsAsFactors=FALSE
      ))
    }
  }
  ev4 <- lr_iface_results

  # -----------------------------------------------------------------------
  # EVIDENCE 5: Sample-level metrics for cross-sample analysis
  # -----------------------------------------------------------------------
  smry <- data.frame(
    Sample=nm, Group=grp,
    Sample_type=md$sample_type[1],
    N_spots=nrow(md),
    N_AR=sum(md$spot_pheno=="AR_epithelial"),
    N_NEPC=n_nepc,
    N_ASPC=sum(md$spot_pheno=="Stromal_ASPC"),
    N_Transition=sum(md$spot_pheno=="Transition"),
    N_Interface=n_interface,
    Pct_Interface=round(n_interface/nrow(md)*100,1),
    Pct_NEPC=round(n_nepc/nrow(md)*100,1),
    Pct_Transition=round(sum(md$spot_pheno=="Transition")/nrow(md)*100,1),
    NEPC_gradient_cor=if(!is.null(ev1)&&exists("ev1_cor")) round(ev1_cor$estimate,4) else NA,
    NEPC_gradient_p=if(!is.null(ev1)&&exists("ev1_cor")) signif(ev1_cor$p.value,4) else NA,
    Trans_at_interface_OR=if(!is.null(ev2)) ev2$Fisher_OR else NA,
    Trans_at_interface_p=if(!is.null(ev2)) ev2$Fisher_p else NA,
    Dist_NEPC_cor=round(ev3_cor,4),
    stringsAsFactors=FALSE
  )

  all_sample_smry[[nm]] <- smry
  all_evidence[[nm]] <- list(ev1=ev1,ev2=ev2,ev3_cor=ev3_cor,ev4=ev4,md=md)

  completed <- c(completed,nm)
  cat(paste0("  DONE -> ",md$sample_type[1],
             " | Interface=",n_interface,
             " | NEPC_gradient_cor=",smry$NEPC_gradient_cor,"\n"))
}

