    if ("ligand" %in% colnames(lr_raw) && "receptor" %in% colnames(lr_raw)) {
      lr_database <- data.frame(
        Ligand = lr_raw$ligand,
        Receptor = lr_raw$receptor,
        stringsAsFactors = FALSE)
    } else if ("interaction_name" %in% colnames(lr_raw)) {
      parts <- strsplit(lr_raw$interaction_name, "_")
      lr_database <- data.frame(
        Ligand = sapply(parts, function(x) x[1]),
        Receptor = sapply(parts, function(x) paste(x[-1], collapse = "_")),
        stringsAsFactors = FALSE)
    }

    if (!is.null(lr_database)) {
      if ("pathway_name" %in% colnames(lr_raw))
        lr_database$Pathway <- lr_raw$pathway_name
      if ("annotation" %in% colnames(lr_raw))
        lr_database$Annotation <- lr_raw$annotation

      if ("complex" %in% names(CellChatDB)) {
        complex_db <- CellChatDB$complex
        resolve_complex <- function(name, complex_db) {
          if (name %in% rownames(complex_db)) {
            genes <- unlist(complex_db[name, ])
            genes <- genes[genes != "" & !is.na(genes)]
            return(genes)
          }
          return(name)
        }
        lr_expanded <- list()
        for (i in 1:nrow(lr_database)) {
          lig_genes <- resolve_complex(lr_database$Ligand[i], complex_db)
          rec_genes <- resolve_complex(lr_database$Receptor[i], complex_db)
          for (lg in lig_genes) {
            for (rg in rec_genes) {
              row <- lr_database[i, , drop = FALSE]
              row$Ligand_original <- lr_database$Ligand[i]
              row$Receptor_original <- lr_database$Receptor[i]
              row$Ligand <- lg
              row$Receptor <- rg
              lr_expanded[[length(lr_expanded) + 1]] <- row
            }
          }
        }
        lr_database <- bind_rows(lr_expanded)
      }

      lr_database <- lr_database[!duplicated(paste0(lr_database$Ligand, "_",
        lr_database$Receptor)), , drop = FALSE]
      cellchat_loaded <- TRUE
      cat(paste0("  Final L-R database: ", nrow(lr_database), " pairs\n"))
      cat(paste0("  Unique ligands: ", length(unique(lr_database$Ligand)), "\n"))
      cat(paste0("  Unique receptors: ", length(unique(lr_database$Receptor)), "\n"))
    }
  }, error = function(e) {
    cat(paste0("  CellChat load error: ", e$message, "\n"))
  })
}

