# CALIBRATE NE_like ABSOLUTE THRESHOLD FROM KNOWN NEPC (NEADT) SAMPLES
# ==============================================================================
cat("\n========== CALIBRATING NE_like THRESHOLD FROM NEADT SAMPLES ==========\n\n")

neadt_dirs <- sample_dirs[grepl("NEADT", sample_dirs)]
calib_dirs <- neadt_dirs[1:min(5, length(neadt_dirs))]
calib_ne_scores <- c()
calib_ne_per_sample <- list()   # store per-sample scores for Fig 10

NE_like_genes <- cell_sigs[["NE_like"]]

for (cd in calib_dirs) {
  bd_cal <- file.path(base_root, cd)
  nm_cal <- sub("^GSM[0-9]+_", "", cd)
  if (!dir.exists(bd_cal)) { cat(paste0("  ", nm_cal, ": not found, skip\n")); next }
  cat(paste0("  Calibrating from: ", nm_cal, " ... "))

  f_bc_c  <- find_file(bd_cal, "barcodes.tsv.gz")
  f_ft_c  <- find_file(bd_cal, "features.tsv.gz")
  f_mx_c  <- find_file(bd_cal, "matrix.mtx.gz")
  f_pos_c <- find_file(bd_cal, "tissue_positions_list.csv")
  if (is.na(f_pos_c)) f_pos_c <- find_file(bd_cal, "tissue_positions.csv")
  f_sf_c  <- find_file(bd_cal, "scalefactors_json.json")
  req_c <- c(f_bc_c, f_ft_c, f_mx_c, f_pos_c, f_sf_c)
  if (any(is.na(req_c))) { cat("missing files, skip\n"); next }

  err_c <- FALSE
  tryCatch({con<-gzfile(f_bc_c,"rt"); barcodes_c<-readLines(con); close(con)},
    error=function(e){err_c<<-TRUE})
  if(err_c) { cat("barcodes error, skip\n"); next }
  tryCatch({con<-gzfile(f_ft_c,"rt"); features_c<-read.delim(con,header=F,stringsAsFactors=F); close(con)},
    error=function(e){err_c<<-TRUE})
  if(err_c) { cat("features error, skip\n"); next }
  tryCatch({con<-gzfile(f_mx_c,"rb"); mat_c<-readMM(con); close(con)},
    error=function(e){err_c<<-TRUE})
  if(err_c) { cat("matrix error, skip\n"); next }
  tryCatch({pos_c<-read.csv(f_pos_c, header=F, stringsAsFactors=F)},
    error=function(e){err_c<<-TRUE})
  if(err_c) { cat("positions error, skip\n"); next }

  colnames(mat_c) <- barcodes_c
  gn_c <- features_c$V2; dup_c <- duplicated(gn_c) | gn_c == ""
  gn_c[dup_c] <- paste0(gn_c[dup_c], "_", features_c$V1[dup_c]); rownames(mat_c) <- gn_c

  if(grepl("barcode", pos_c$V1[1], ignore.case=T)) pos_c <- pos_c[-1,]
  colnames(pos_c) <- c("barcode","in_tissue","array_row","array_col","pxl_row","pxl_col")
  pos_c$in_tissue <- as.integer(pos_c$in_tissue)
  rownames(pos_c) <- pos_c$barcode

  it_bc_c <- intersect(barcodes_c, pos_c$barcode[pos_c$in_tissue == 1])
  if (length(it_bc_c) < 50) { cat("too few spots, skip\n"); next }

  sobj_c <- CreateSeuratObject(counts = mat_c[, it_bc_c], assay = "Spatial", project = nm_cal)
  sobj_c[["pct_mt"]] <- PercentageFeatureSet(sobj_c, pattern = "^MT-")
  med_mt_c <- median(sobj_c$pct_mt)
  mt_th_c <- if (med_mt_c > 30) min(100, med_mt_c + 1.5 * mad(sobj_c$pct_mt, constant = 1)) else 30
  nf_min_c <- 200
  if (sum(sobj_c$nFeature_Spatial > 200 & sobj_c$pct_mt < mt_th_c) < 50) nf_min_c <- 100
  if (sum(sobj_c$nFeature_Spatial > nf_min_c & sobj_c$pct_mt < mt_th_c) < 50) nf_min_c <- 50
  sobj_c <- subset(sobj_c, nFeature_Spatial > nf_min_c & nFeature_Spatial < 10000 & pct_mt < mt_th_c)
  if (ncol(sobj_c) < 30) { cat("too few spots after QC, skip\n"); next }

  sobj_c <- SCTransform(sobj_c, assay = "Spatial", verbose = FALSE)

  ctrl_sz_c <- min(100, floor(nrow(sobj_c) / 4)); nb_c <- max(5, min(24, ncol(sobj_c) - 1))
  av_c <- NE_like_genes[NE_like_genes %in% rownames(sobj_c)]
  if (length(av_c) >= 2) {
    sobj_c <- tryCatch({
      AddModuleScore(sobj_c, features = list(av_c), name = "NE_like_", ctrl = ctrl_sz_c, nbin = nb_c)
    }, error = function(e) {
      em_c <- as.matrix(safe_GetAssayData(sobj_c, "data"))
      sc_c <- colMeans(em_c[av_c, , drop = FALSE])
      bg_c <- sample(setdiff(rownames(sobj_c), av_c), min(ctrl_sz_c, nrow(sobj_c) - length(av_c)))
      if (length(bg_c) > 0) sc_c <- sc_c - colMeans(em_c[bg_c, , drop = FALSE])
      sobj_c[["NE_like_1"]] <- sc_c
      sobj_c
    })
    calib_ne_scores <- c(calib_ne_scores, sobj_c$NE_like_1)
    calib_ne_per_sample[[nm_cal]] <- sobj_c$NE_like_1
    cat(paste0(ncol(sobj_c), " spots scored (", sum(sobj_c$NE_like_1 > 0), " positive)\n"))
  } else {
    cat("too few NE_like genes detected, skip\n")
  }

  rm(sobj_c, mat_c, pos_c, barcodes_c, features_c); gc(verbose = FALSE)
}

if (length(calib_ne_scores) > 50) {
  NE_LIKE_THRESHOLD <- as.numeric(quantile(calib_ne_scores, 0.75, na.rm = TRUE))
  if (NE_LIKE_THRESHOLD < 0.05) NE_LIKE_THRESHOLD <- 0.10
  cat(paste0("\n  >>> NE_LIKE_THRESHOLD = ", round(NE_LIKE_THRESHOLD, 4),
             " (75th percentile of ", length(calib_ne_scores), " NEADT spots)\n"))
} else {
  NE_LIKE_THRESHOLD <- 0.15
  cat(paste0("\n  >>> NE_LIKE_THRESHOLD = 0.15 (fallback — insufficient calibration data)\n"))
}
cat(paste0("  >>> Spots must have NE_like_1 >= ", round(NE_LIKE_THRESHOLD, 4),
           " to be called NE_like_hi\n"))
cat("  >>> This eliminates BPH false positives from random score noise\n")
cat("  >>> Other cell types retain per-sample quantile(0.75) thresholds\n\n")

# ==============================================================================
# MAIN LOOP
# ==============================================================================
cat("\n========== PROCESSING 52 SAMPLES ==========\n\n")

all_niche <- list()
all_niche_bgcorr <- list()
all_niche_perm <- list()
all_lr_niche_ct <- list()
all_lr_global <- list()
all_sample_meta <- list()
all_ne_scores_by_group <- list()   # collect NE scores per group for Fig 8

for (sd in sample_dirs) {
  bd <- file.path(base_root, sd)
  if (!dir.exists(bd)) { cat(paste0("  SKIP (not found): ", sd, "\n")); next }
  nm <- sub("^GSM[0-9]+_", "", sd)
  grp <- "UNKNOWN"
  if (grepl("^BPH",  nm)) grp <- "BPH"
  if (grepl("^TRNA", nm)) grp <- "TRNA"
  if (grepl("^NEADT",nm)) grp <- "NEADT"
  if (grepl("^CRPC", nm)) grp <- "CRPC"
  if (grepl("^MET",  nm)) grp <- "MET"

  t0 <- Sys.time()
  cat(paste0("--- ", nm, " [", grp, "] ---\n"))

  # --- Find files ---
  f_bc  <- find_file(bd, "barcodes.tsv.gz")
  f_ft  <- find_file(bd, "features.tsv.gz")
  f_mx  <- find_file(bd, "matrix.mtx.gz")
  f_pos <- find_file(bd, "tissue_positions_list.csv")
  if (is.na(f_pos)) f_pos <- find_file(bd, "tissue_positions.csv")
  f_sf  <- find_file(bd, "scalefactors_json.json")
  req <- c(f_bc, f_ft, f_mx, f_pos, f_sf)
  if (any(is.na(req))) { cat("  SKIP (missing files)\n"); next }

  # --- Load ---
  err <- FALSE
  tryCatch({con<-gzfile(f_bc,"rt"); barcodes<-readLines(con); close(con)},
    error=function(e){err<<-TRUE})
  if(err) { cat("  SKIP (barcodes error)\n"); next }
  tryCatch({con<-gzfile(f_ft,"rt"); features<-read.delim(con,header=F,stringsAsFactors=F); close(con)},
    error=function(e){err<<-TRUE})
  if(err) { cat("  SKIP (features error)\n"); next }
  tryCatch({con<-gzfile(f_mx,"rb"); mat<-readMM(con); close(con)},
    error=function(e){err<<-TRUE})
  if(err) { cat("  SKIP (matrix error)\n"); next }
  tryCatch({pos<-read.csv(f_pos, header=F, stringsAsFactors=F)},
    error=function(e){err<<-TRUE})
  if(err) { cat("  SKIP (positions error)\n"); next }
  tryCatch({sf_json<-fromJSON(f_sf)}, error=function(e){err<<-TRUE})
  if(err) { cat("  SKIP (scalefactors error)\n"); next }

  colnames(mat) <- barcodes
  gn <- features$V2
  dup <- duplicated(gn) | gn == ""
  gn[dup] <- paste0(gn[dup], "_", features$V1[dup])
  rownames(mat) <- gn

  if(grepl("barcode", pos$V1[1], ignore.case=T)) pos <- pos[-1,]
  colnames(pos) <- c("barcode","in_tissue","array_row","array_col","pxl_row","pxl_col")
  pos$in_tissue <- as.integer(pos$in_tissue)
  pos$pxl_row <- as.numeric(pos$pxl_row)
  pos$pxl_col <- as.numeric(pos$pxl_col)
  rownames(pos) <- pos$barcode

  it_bc <- intersect(barcodes, pos$barcode[pos$in_tissue == 1])
  if(length(it_bc) < 50) { cat("  SKIP (<50 in-tissue)\n"); next }

  # --- Create Seurat + normalize ---
  sobj <- CreateSeuratObject(counts = mat[, it_bc], assay = "Spatial", project = nm)
  sobj$spatial_x <- pos[Cells(sobj), "pxl_col"]
  sobj$spatial_y <- pos[Cells(sobj), "pxl_row"]
  sobj[["pct_mt"]] <- PercentageFeatureSet(sobj, pattern = "^MT-")
  med_mt <- median(sobj$pct_mt)
  mt_th <- if(med_mt > 30) min(100, med_mt + 1.5 * mad(sobj$pct_mt, constant=1)) else 30
  nf_min <- 200
  if(sum(sobj$nFeature_Spatial > 200 & sobj$pct_mt < mt_th) < 50) nf_min <- 100
  if(sum(sobj$nFeature_Spatial > nf_min & sobj$pct_mt < mt_th) < 50) nf_min <- 50
  sobj <- subset(sobj, nFeature_Spatial > nf_min & nFeature_Spatial < 10000 & pct_mt < mt_th)
  if(ncol(sobj) < 30) { cat("  SKIP (<30 after QC)\n"); rm(sobj,mat); gc(verbose=F); next }
  sobj <- SCTransform(sobj, assay = "Spatial", verbose = FALSE)
  cat(paste0("  Spots: ", ncol(sobj), " | Genes: ", nrow(sobj), "\n"))

  ed <- as.matrix(safe_GetAssayData(sobj, "data"))
  ag <- rownames(sobj)
  ctrl_sz <- min(100, floor(nrow(sobj)/4))
  nb_bins <- max(5, min(24, ncol(sobj)-1))

  # --- Score cell types + ASPC + NEPC ---
  sscore <- function(obj, genes, prefix) {
    av <- genes[genes %in% rownames(obj)]
    if (length(av) < 2) return(list(obj=obj, ok=FALSE))
    tryCatch({
      obj <- AddModuleScore(obj, features=list(av), name=prefix, ctrl=ctrl_sz, nbin=nb_bins)
      list(obj=obj, ok=TRUE)
    }, error=function(e) {
      em <- as.matrix(safe_GetAssayData(obj,"data"))
      sc <- colMeans(em[av,,drop=F])
      bg <- sample(setdiff(rownames(obj), av), min(ctrl_sz, nrow(obj)-length(av)))
      if(length(bg) > 0) sc <- sc - colMeans(em[bg,,drop=F])
      obj[[paste0(prefix,"1")]] <- sc
      list(obj=obj, ok=TRUE)
    })
  }

  for (ct in names(cell_sigs)) {
    r <- sscore(sobj, cell_sigs[[ct]], paste0(ct,"_")); sobj <- r$obj
  }
  r <- sscore(sobj, ASPC_genes, "ASPC_"); sobj <- r$obj
  r <- sscore(sobj, NEPC_UP, "NEPC_UP_"); sobj <- r$obj
  r <- sscore(sobj, NEPC_DN, "NEPC_DN_"); sobj <- r$obj
  r <- sscore(sobj, Hallmark_AR, "AR_"); sobj <- r$obj

  md <- sobj@meta.data
  md$spatial_x <- sobj$spatial_x; md$spatial_y <- sobj$spatial_y
  md$sample <- nm; md$group <- grp
  md$NEPC_composite <- md$NEPC_UP_1 - md$NEPC_DN_1

  md$ASPC_hi <- md$ASPC_1 >= quantile(md$ASPC_1, 0.75)
  n_aspc <- sum(md$ASPC_hi)
  if (n_aspc < 5) { cat("  SKIP (<5 ASPC-hi)\n"); rm(sobj,ed,mat); gc(verbose=F); next }

  # -----------------------------------------------------------------------
  # Cell-type _hi classification (v2: absolute threshold for NE_like)
  # -----------------------------------------------------------------------
  ct_hi_cols <- c()
  for (ct in names(cell_sigs)) {
    sc <- paste0(ct, "_1")
    if (sc %in% colnames(md)) {
      hi_col <- paste0(ct, "_hi")
      if (ct == "NE_like") {
        md[[hi_col]] <- md[[sc]] >= NE_LIKE_THRESHOLD
      } else {
        md[[hi_col]] <- md[[sc]] >= quantile(md[[sc]], 0.75)
      }
      ct_hi_cols <- c(ct_hi_cols, ct)
    }
  }

  # Collect NE_like scores per group for Fig 8
  if ("NE_like_1" %in% colnames(md)) {
    all_ne_scores_by_group[[nm]] <- data.frame(
      NE_like_score = md$NE_like_1, sample = nm, group = grp,
      stringsAsFactors = FALSE)
  }

  n_total_spots <- nrow(md)
  n_ne_hi <- if ("NE_like_hi" %in% colnames(md)) sum(md$NE_like_hi) else 0
  pct_ne_hi <- n_ne_hi / n_total_spots

  # ==================================================================
  # NICHE ANALYSIS + CONTROL 1 + CONTROL 2
  # ==================================================================
  cat("  Niche+Ctrl...")
  sr <- sf_json$spot_diameter_fullres * 3
  xy <- as.matrix(md[, c("spatial_x","spatial_y")])
  nbl <- precompute_neighbors(xy, sr)

  aspc_idx <- which(md$ASPC_hi)
  non_aspc_idx <- which(!md$ASPC_hi)
  all_spot_idx <- 1:nrow(md)

  niche_rows <- list()
  niche_bgcorr_rows <- list()
  niche_perm_rows <- list()

  for (ct in ct_hi_cols) {
    sc <- paste0(ct, "_1")
    ct_hi_idx <- which(md[[paste0(ct, "_hi")]])

    nbr_aspc <- vapply(aspc_idx, function(i) {
      nb <- nbl[[i]]
      if(length(nb) < 1) NA_real_ else mean(md[[sc]][nb])
    }, numeric(1))

    nbr_bg <- vapply(non_aspc_idx, function(i) {
      nb <- nbl[[i]]
      if(length(nb) < 1) NA_real_ else mean(md[[sc]][nb])
    }, numeric(1))

    m_aspc <- mean(nbr_aspc, na.rm=TRUE)
    m_bg <- mean(nbr_bg, na.rm=TRUE)
    enrichment <- log2((m_aspc + 0.001) / (m_bg + 0.001))
    pv <- tryCatch(wilcox.test(nbr_aspc, nbr_bg)$p.value, error=function(e) NA_real_)

    n_ct_near_aspc <- sum(vapply(aspc_idx, function(i) {
      any(nbl[[i]] %in% ct_hi_idx)
    }, logical(1)))

    niche_rows[[ct]] <- data.frame(
      CellType = ct,
      Nbr_ASPC_mean = round(m_aspc, 5), Nbr_BG_mean = round(m_bg, 5),
      Enrichment = round(enrichment, 4), P_value = signif(pv, 3),
      N_CT_near_ASPC = n_ct_near_aspc, N_ASPC_spots = n_aspc,
      sample = nm, group = grp, stringsAsFactors = FALSE)

    # CONTROL 1
    global_mean_ct <- mean(md[[sc]], na.rm = TRUE)
    bgcorr_aspc <- m_aspc - global_mean_ct
    bgcorr_bg   <- m_bg - global_mean_ct
    bgcorr_enrichment <- bgcorr_aspc - bgcorr_bg

    niche_bgcorr_rows[[ct]] <- data.frame(
      CellType = ct,
      Global_mean = round(global_mean_ct, 5),
      Niche_ASPC_mean = round(m_aspc, 5),
      Niche_BG_mean = round(m_bg, 5),
      ASPC_above_global = round(bgcorr_aspc, 5),
      BG_above_global = round(bgcorr_bg, 5),
      BgCorr_enrichment = round(bgcorr_enrichment, 5),
      Raw_enrichment = round(enrichment, 4),
      sample = nm, group = grp, stringsAsFactors = FALSE)

    # CONTROL 2
    perm_means <- numeric(N_PERMUTATIONS)
    for (p in 1:N_PERMUTATIONS) {
      rand_idx <- sample(all_spot_idx, n_aspc, replace = FALSE)
      rand_nbr <- vapply(rand_idx, function(i) {
        nb <- nbl[[i]]
        if(length(nb) < 1) NA_real_ else mean(md[[sc]][nb])
      }, numeric(1))
      perm_means[p] <- mean(rand_nbr, na.rm = TRUE)
    }
    perm_mean_null <- mean(perm_means)
    perm_sd_null <- sd(perm_means)
    perm_zscore <- if (perm_sd_null > 0) (m_aspc - perm_mean_null) / perm_sd_null else 0
    perm_p_greater <- (sum(perm_means >= m_aspc) + 1) / (N_PERMUTATIONS + 1)
    perm_p_lesser  <- (sum(perm_means <= m_aspc) + 1) / (N_PERMUTATIONS + 1)
    perm_p <- 2 * min(perm_p_greater, perm_p_lesser)
    perm_p <- min(perm_p, 1)

    niche_perm_rows[[ct]] <- data.frame(
      CellType = ct,
      Observed_ASPC_niche = round(m_aspc, 5),
      Perm_null_mean = round(perm_mean_null, 5),
      Perm_null_sd = round(perm_sd_null, 5),
      Perm_Zscore = round(perm_zscore, 3),
      Perm_P = signif(perm_p, 3),
      ASPC_above_null = round(m_aspc - perm_mean_null, 5),
      Raw_enrichment = round(enrichment, 4),
      N_perms = N_PERMUTATIONS,
      sample = nm, group = grp, stringsAsFactors = FALSE)
  }

  all_niche[[nm]] <- bind_rows(niche_rows)
  all_niche_bgcorr[[nm]] <- bind_rows(niche_bgcorr_rows)
  all_niche_perm[[nm]] <- bind_rows(niche_perm_rows)
  cat("done ")

  # ==================================================================
  # L-R GENE READOUT ANALYSIS
  # ==================================================================
  cat("LR...")

  ct_nbr_aspc <- list()
  ct_nbr_bg <- list()
  for (ct in ct_hi_cols) {
    ct_hi_idx <- which(md[[paste0(ct, "_hi")]])
    if (length(ct_hi_idx) < 2) {
      ct_nbr_aspc[[ct]] <- integer(0)
      ct_nbr_bg[[ct]] <- integer(0)
      next
    }
    near_aspc <- unique(unlist(lapply(aspc_idx, function(i) {
      intersect(nbl[[i]], ct_hi_idx)
    })))
    near_bg_pool <- unique(unlist(lapply(
      sample(non_aspc_idx, min(500, length(non_aspc_idx))), function(i) {
        intersect(nbl[[i]], ct_hi_idx)
    })))
    near_bg <- setdiff(near_bg_pool, near_aspc)
    if (length(near_bg) < 2) near_bg <- near_bg_pool
    ct_nbr_aspc[[ct]] <- near_aspc
    ct_nbr_bg[[ct]] <- near_bg
  }

  lr_ct_rows <- list()
  lr_global_rows <- list()

  for (k in 1:nrow(lr_database)) {
    lig <- lr_database$Ligand[k]
    rec <- lr_database$Receptor[k]
    if (!(lig %in% ag) || !(rec %in% ag)) next

    rec_in_aspc <- mean(ed[rec, aspc_idx])
    rec_in_bg   <- mean(ed[rec, non_aspc_idx])
    rec_aspc_enrich <- log2((rec_in_aspc + 0.001) / (rec_in_bg + 0.001))

    if (rec_in_aspc < 1e-8) next

    pw <- if ("Pathway" %in% colnames(lr_database)) lr_database$Pathway[k] else NA_character_
    ann <- if ("Annotation" %in% colnames(lr_database)) lr_database$Annotation[k] else NA_character_

    best_ct <- NA_character_; best_int <- -Inf
    best_lig_near <- 0; best_lig_far <- 0

    for (ct in ct_hi_cols) {
      ct_near <- ct_nbr_aspc[[ct]]
      ct_far <- ct_nbr_bg[[ct]]
      if (length(ct_near) < 1) next

      lig_in_ct_near_aspc <- mean(ed[lig, ct_near])
      lig_in_ct_far <- if (length(ct_far) >= 1) mean(ed[lig, ct_far]) else 0
      if (lig_in_ct_near_aspc < 1e-8) next

      interaction_near <- lig_in_ct_near_aspc * rec_in_aspc
      interaction_far  <- lig_in_ct_far * rec_in_bg
      int_enrich <- log2((interaction_near + 1e-6) / (interaction_far + 1e-6))

      lr_ct_rows[[length(lr_ct_rows)+1]] <- data.frame(
        Ligand = lig, Receptor = rec,
        Pathway = pw, Annotation = ann,
        Source_CT = ct,
        Lig_in_CT_near_ASPC = round(lig_in_ct_near_aspc, 5),
        Lig_in_CT_far = round(lig_in_ct_far, 5),
        Rec_in_ASPC = round(rec_in_aspc, 5),
        Rec_in_BG = round(rec_in_bg, 5),
        Rec_ASPC_enrich = round(rec_aspc_enrich, 4),
        Interaction_near = round(interaction_near, 6),
        Interaction_far = round(interaction_far, 6),
        Int_enrich = round(int_enrich, 4),
        N_CT_near_ASPC = length(ct_near),
        sample = nm, group = grp,
        stringsAsFactors = FALSE)

      if (interaction_near > best_int) {
        best_int <- interaction_near
        best_ct <- ct
        best_lig_near <- lig_in_ct_near_aspc
        best_lig_far <- lig_in_ct_far
      }
    }

    if (!is.na(best_ct)) {
      lr_global_rows[[length(lr_global_rows)+1]] <- data.frame(
        Ligand = lig, Receptor = rec,
        Pathway = pw, Annotation = ann,
        Best_source = best_ct,
        Lig_near_ASPC = round(best_lig_near, 5),
        Lig_far = round(best_lig_far, 5),
        Rec_ASPC = round(rec_in_aspc, 5),
        Rec_BG = round(rec_in_bg, 5),
        Rec_enrich = round(rec_aspc_enrich, 4),
        Interaction = round(best_int, 6),
        sample = nm, group = grp,
        stringsAsFactors = FALSE)
    }
  }

  if (length(lr_ct_rows) > 0) all_lr_niche_ct[[nm]] <- bind_rows(lr_ct_rows)
  if (length(lr_global_rows) > 0) all_lr_global[[nm]] <- bind_rows(lr_global_rows)
  cat("done ")

  all_sample_meta[[nm]] <- data.frame(
    sample = nm, group = grp,
    N_spots = n_total_spots, N_ASPC_hi = n_aspc,
    Pct_ASPC = round(n_aspc / n_total_spots * 100, 1),
    N_NE_hi = n_ne_hi,
    Pct_NE_hi = round(pct_ne_hi * 100, 2),
    Mean_ASPC = round(mean(md$ASPC_1), 4),
    Mean_NEPC = round(mean(md$NEPC_composite), 4),
    Mean_AR = round(mean(md$AR_1), 4),
    NE_like_threshold = round(NE_LIKE_THRESHOLD, 4),
    stringsAsFactors = FALSE)

