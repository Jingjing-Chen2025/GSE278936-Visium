theme_pub <- function(base_size = 10) {
  theme_classic(base_size = base_size) %+replace%
    theme(
      text = element_text(color = "black"),
      axis.text = element_text(color = "black", size = rel(0.85)),
      axis.title = element_text(size = rel(1), face = "bold"),
      axis.line = element_line(color = "black", linewidth = 0.4),
      plot.title = element_text(size = rel(1.1), face = "bold", hjust = 0.5),
      plot.subtitle = element_text(size = rel(0.85), hjust = 0.5, color = "grey30"),
      legend.text = element_text(size = rel(0.8)),
      legend.title = element_text(size = rel(0.85), face = "bold"),
      panel.grid = element_blank(),
      plot.margin = margin(8, 10, 6, 8))
}

pal_nepc <- c("NEPC > Adeno" = "#8E44AD", "Adeno > NEPC" = "#2980B9")

save_fig <- function(p, name, w = 7, h = 5) {
  w <- max(4, min(w, 48))
  h <- max(4, min(h, 48))
  ggsave(file.path(out_root, "05_Figures", paste0(name, ".png")), p,
    w = w, h = h, dpi = 300, bg = "white")
  ggsave(file.path(out_root, "05_Figures", paste0(name, ".pdf")), p,
    w = w, h = h, device = cairo_pdf, bg = "white")
  cat(paste0("  Saved: ", name, " (", w, "x", h, " in)\n"))
}

