find_file <- function(base, suffix) {
  hits <- list.files(base, recursive = TRUE, full.names = TRUE)
  hits <- hits[grepl(paste0(gsub("\\.", "\\\\.", suffix), "$"), hits)]
  if (length(hits) == 0) NA_character_ else hits[1]
}

safe_GetAssayData <- function(obj, ln = "data") {
  tryCatch(GetAssayData(obj, layer = ln),
    error = function(e) tryCatch(GetAssayData(obj, slot = ln),
      error = function(e2) obj[[DefaultAssay(obj)]]@data))
}

precompute_neighbors <- function(xy, radius) {
  n <- nrow(xy)
  lapply(1:n, function(i) {
    d <- sqrt((xy[,1] - xy[i,1])^2 + (xy[,2] - xy[i,2])^2)
    which(d > 0 & d <= radius)
  })
}

clamp_h <- function(h, min_h = 4, max_h = 48) {
  max(min_h, min(h, max_h))
}

