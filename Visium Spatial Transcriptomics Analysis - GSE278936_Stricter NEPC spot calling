## ---- 6b. Pool all spots & robust z-score signatures globally ---------------
per_spot_df <- dplyr::bind_rows(raw_spot_list, .id = "sample_id_key")

robust_z <- function(x) {
  m <- median(x, na.rm = TRUE)
  s <- mad(x, na.rm = TRUE)
  if (is.na(s) || s == 0) s <- sd(x, na.rm = TRUE)
  if (is.na(s) || s == 0) return(rep(0, length(x)))
  (x - m) / s
}

per_spot_df <- per_spot_df %>%
  dplyr::mutate(
    ASPC_z    = robust_z(ASPC_score),
    AR_z      = robust_z(AR_score),
    NEPC_UP_z = robust_z(NEPC_UP_1),
    NEPC_DN_z = robust_z(NEPC_DN_1),
    ADIPO_z   = robust_z(ADIPO_score)
  )

## ---- 6c. Spot-level classification (stricter NEPC) -------------------------
# NEPC+ spot requires BOTH: neuroendocrine UP high AND AR/luminal DOWN-set low.
# Prevents stromal/basal (common in BPH) from being mis-called NEPC.
NEPC_UP_CUT <- 1.0     # ~top 16% of pooled spots
NEPC_DN_CUT <- -0.5    # AR/luminal program suppressed
ASPC_CUT    <- 0
AR_CUT      <- 0

per_spot_df <- per_spot_df %>%
  dplyr::mutate(
    is_ASPC = ASPC_score > ASPC_CUT,
    is_AR   = AR_score   > AR_CUT,
    is_NEPC = (NEPC_UP_z > NEPC_UP_CUT) & (NEPC_DN_z < NEPC_DN_CUT),
    is_ASPC_AR_interface = is_ASPC & is_AR
  )

readr::write_csv(per_spot_df, file.path(OUT_DIR, "per_spot_scores.csv"))

## ---- 7. Per-sample summary & classification --------------------------------
# Rule:
#   BPH  -> always "Benign"
#   Cancer categories -> "NEPC" if >5% NEPC+ spots, else "Adenocarcinoma"
per_sample_df <- per_spot_df %>%
  dplyr::group_by(sample_id, category) %>%
  dplyr::summarise(
    n_spots               = dplyr::n(),
    pct_NEPC_spots        = 100 * mean(is_NEPC, na.rm = TRUE),
    pct_ASPC_AR_interface = 100 * mean(is_ASPC_AR_interface, na.rm = TRUE),
    mean_ASPC             = mean(ASPC_score,  na.rm = TRUE),
    mean_AR               = mean(AR_score,    na.rm = TRUE),
    mean_ADIPO            = mean(ADIPO_score, na.rm = TRUE),
    mean_NEPC_UP          = mean(NEPC_UP_1,   na.rm = TRUE),
    mean_NEPC_DN          = mean(NEPC_DN_1,   na.rm = TRUE),
    .groups = "drop"
  ) %>%
  dplyr::mutate(
    sample_type = dplyr::case_when(
      category == "BPH"   ~ "Benign",
      pct_NEPC_spots > 5  ~ "NEPC",
      TRUE                ~ "Adenocarcinoma"
    )
  )

readr::write_csv(per_sample_df, file.path(OUT_DIR, "per_sample_summary.csv"))

