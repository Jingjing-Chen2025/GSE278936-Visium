  s_path <- sample_roster$path[i]

  obj <- tryCatch(load_visium_sample(s_path, s_id),
                  error = function(e) { message("  load failed: ", e$message); NULL })
  if (is.null(obj)) next

  obj <- score_sample(obj, s_id)
  md  <- obj@meta.data
  md$category <- s_cat
  raw_spot_list[[s_id]] <- md
}

