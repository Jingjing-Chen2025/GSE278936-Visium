stat_results <- cancer_df %>%
  dplyr::group_by(category) %>%
  dplyr::group_modify(~{
    d <- .x
    types <- droplevels(d$sample_type)
    if (length(unique(types)) < 2 || any(table(types) < 2)) {
      return(data.frame(p_value = NA_real_, method = "insufficient_n",
                        n_adeno = sum(d$sample_type == "Adenocarcinoma"),
                        n_nepc  = sum(d$sample_type == "NEPC")))
    }
    tt <- tryCatch(wilcox.test(pct_ASPC_AR_interface ~ sample_type, data = d),
                   error = function(e) NULL)
    data.frame(p_value = if (is.null(tt)) NA_real_ else tt$p.value,
               method  = "wilcoxon",
               n_adeno = sum(d$sample_type == "Adenocarcinoma"),
               n_nepc  = sum(d$sample_type == "NEPC"))
  }) %>% dplyr::ungroup()

