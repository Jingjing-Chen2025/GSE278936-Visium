## ---- 3. Flexible loaders (handle GSM-prefixed filenames) --------------------
find_10x_file <- function(dir, patterns) {
  files <- list.files(dir, full.names = TRUE)
  for (pat in patterns) {
    hit <- files[grepl(pat, basename(files), ignore.case = TRUE)]
    if (length(hit) > 0) return(hit[1])
  }
  NA_character_
}

read_10x_flexible <- function(mat_dir) {
  bc_f <- find_10x_file(mat_dir, c("barcodes\\.tsv\\.gz$", "barcodes\\.tsv$"))
  ft_f <- find_10x_file(mat_dir, c("features\\.tsv\\.gz$", "features\\.tsv$",
                                   "genes\\.tsv\\.gz$",    "genes\\.tsv$"))
  mx_f <- find_10x_file(mat_dir, c("matrix\\.mtx\\.gz$",   "matrix\\.mtx$"))
  if (any(is.na(c(bc_f, ft_f, mx_f))))
    stop("Missing 10x files in ", mat_dir)

  mat <- Matrix::readMM(mx_f)
  bcs <- readLines(bc_f)
  fts <- read.delim(ft_f, header = FALSE, stringsAsFactors = FALSE)
  gene_names <- if (ncol(fts) >= 2) fts[[2]] else fts[[1]]
  gene_names <- make.unique(gene_names)
  rownames(mat) <- gene_names
  colnames(mat) <- bcs
  as(mat, "CsparseMatrix")
}

read_image_flexible <- function(spa_dir) {
  img_f   <- find_10x_file(spa_dir, c("tissue_lowres_image\\.png$",
                                      "tissue_hires_image\\.png$"))
  scale_f <- find_10x_file(spa_dir, c("scalefactors_json\\.json$"))
  pos_f   <- find_10x_file(spa_dir, c("tissue_positions\\.csv\\.gz$",
                                      "tissue_positions\\.csv$",
                                      "tissue_positions_list\\.csv\\.gz$",
                                      "tissue_positions_list\\.csv$"))
  if (any(is.na(c(img_f, scale_f, pos_f)))) {
    warning("Missing spatial files in ", spa_dir, " — continuing without image.")
    return(NULL)
  }
  tmp <- file.path(tempdir(),
                   paste0("spa_", basename(dirname(spa_dir)), "_",
                          as.integer(Sys.time()), "_", sample.int(1e6, 1)))
  dir.create(tmp, showWarnings = FALSE, recursive = TRUE)
  file.copy(img_f,   file.path(tmp, "tissue_lowres_image.png"),  overwrite = TRUE)
  file.copy(scale_f, file.path(tmp, "scalefactors_json.json"),   overwrite = TRUE)
  pos_dest <- if (grepl("_list", basename(pos_f)))
    "tissue_positions_list.csv" else "tissue_positions.csv"
  if (grepl("\\.gz$", pos_f)) pos_dest <- paste0(pos_dest, ".gz")
  file.copy(pos_f, file.path(tmp, pos_dest), overwrite = TRUE)

  tryCatch(
    Seurat::Read10X_Image(image.dir = tmp, filter.matrix = TRUE),
    error = function(e) { message("   image load failed: ", e$message); NULL }
  )
}

## ---- 4. Seurat v4/v5-compatible sample loader ------------------------------
load_visium_sample <- function(sample_path, sample_id) {
  message(">> Loading ", sample_id)
  mat_dir <- file.path(sample_path, "filtered_feature_bc_matrix")
  spa_dir <- file.path(sample_path, "spatial")

  counts <- read_10x_flexible(mat_dir)
  obj <- Seurat::CreateSeuratObject(counts = counts, assay = "Spatial",
                                    project = sample_id)

  img <- read_image_flexible(spa_dir)
  if (!is.null(img)) {
    img_barcodes <- tryCatch(
      rownames(Seurat::GetTissueCoordinates(img)),
      error = function(e) tryCatch(rownames(img@coordinates),
                                   error = function(e2) NULL)
    )
    if (!is.null(img_barcodes) && length(img_barcodes) > 0) {
      common <- intersect(colnames(obj), img_barcodes)
      if (length(common) > 0) {
        obj <- obj[, common]
        img <- tryCatch(img[common], error = function(e) img)
      }
    }
    Seurat::DefaultAssay(img) <- "Spatial"
    obj[[sample_id]] <- img
  }
  obj$sample_id <- sample_id
  obj
}

## ---- 5. Scoring ------------------------------------------------------------
score_sample <- function(obj, sample_id) {
  obj <- Seurat::NormalizeData(obj, verbose = FALSE)
  add_score <- function(obj, genes, name) {
    genes <- intersect(genes, rownames(obj))
    if (length(genes) < 3) { obj[[name]] <- 0; return(obj) }
    Seurat::AddModuleScore(obj, features = list(genes),
                           name = name, assay = "Spatial")
  }
  obj <- add_score(obj, ASPC_SIGNATURE,             "ASPC_")
  obj <- add_score(obj, HALLMARK_ADIPOGENESIS,      "ADIPO_")
  obj <- add_score(obj, NEPC_UP,                    "NEPC_UP_")
  obj <- add_score(obj, NEPC_DOWN,                  "NEPC_DN_")
  obj <- add_score(obj, HALLMARK_ANDROGEN_RESPONSE, "AR_")

  md <- obj@meta.data
  md$ASPC_score  <- md$ASPC_1
  md$ADIPO_score <- md$ADIPO_1
  md$AR_score    <- md$AR_1
  md$NEPC_score  <- md$NEPC_UP_1 - md$NEPC_DN_1
  md$sample_id   <- sample_id
  obj@meta.data <- md
  obj
}

